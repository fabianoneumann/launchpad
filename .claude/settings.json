{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"$CLAUDE_PROJECT_DIR/.claude/format-hook.ps1\"",
            "timeout": 30,
            "statusMessage": "Formatando com Prettier..."
          }
        ]
      }
    ]
  }
}
