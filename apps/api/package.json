{
  "name": "@eco-iguassu/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node build/server.js",
    "build": "prisma generate && tsup",
    "test": "vitest run --dir src/modules --passWithNoTests",
    "test:watch": "vitest --dir src/modules",
    "test:e2e": "vitest run --dir src/modules --reporter=verbose --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.0.0",
    "resend": "^6.9.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.0.0",
    "supertest": "^7.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
